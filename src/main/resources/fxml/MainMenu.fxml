<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>

<VBox xmlns="http://javafx.com/javafx/17.0.6" 
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.homework.osexperiment.osexp.controller.MainMenuController"
      spacing="30"
      alignment="CENTER"
      styleClass="main-container">
    
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>
    
    <!-- 标题 -->
    <Label text="操作系统实验模拟系统" 
           styleClass="title-label"/>
    
    <Label text="请选择实验项目" 
           styleClass="subtitle-label"/>
    
    <!-- 实验选择按钮区域 -->
    <VBox spacing="20" 
          alignment="CENTER"
          maxWidth="400">
        
        <!-- 实验一：进程并发 -->
        <Button text="实验一：进程并发模拟"
                fx:id="btnProcessConcurrency"
                onAction="#handleProcessConcurrency"
                prefWidth="300"
                prefHeight="50"
                styleClass="experiment-button"/>
        
        <!-- 实验二：生产者消费者问题 -->
        <Button text="实验二：生产者与消费者问题"
                fx:id="btnProducerConsumer"
                onAction="#handleProducerConsumer"
                prefWidth="300"
                prefHeight="50"
                styleClass="experiment-button"/>
        
        <!-- 实验三：进程调度 -->
        <Button text="实验三：进程调度模拟"
                fx:id="btnProcessScheduling"
                onAction="#handleProcessScheduling"
                prefWidth="300"
                prefHeight="50"
                styleClass="experiment-button"/>
        
    </VBox>
    
    <!-- 作者信息 -->
    <VBox spacing="5" alignment="CENTER">
        <Label text="姓名：谢云轩" styleClass="author-label"/>
        <Label text="学号：632307060623" styleClass="author-label"/>
    </VBox>
    
</VBox>
